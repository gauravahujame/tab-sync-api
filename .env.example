# =============================================================================
# Tab-Sync-API Environment Configuration
# =============================================================================
# Copy this file to .env and modify as needed.
# For Docker deployment, these values are passed to containers.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port the API listens on (inside container) and external mapping
PORT=3000

# Environment: development, production, test
NODE_ENV=development

# Domain for reverse proxy trust (e.g., api.example.com)
# Leave empty for direct access without proxy
DOMAIN=

# Timezone
TZ=UTC

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# DB_TYPE: sqlite (default) or postgres
DB_TYPE=sqlite

# SQLite Configuration (used when DB_TYPE=sqlite)
# For Docker, use /data/tabs.db. For local dev, use ./data/tabs.db
DATABASE_PATH=./data/tabs.db

# PostgreSQL Configuration (used when DB_TYPE=postgres)
# Uncomment and configure for PostgreSQL:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=tabsync
# DB_PASSWORD=your-secure-password
# DB_NAME=tabsync

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# IMPORTANT: Change this in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=change-this-in-production-use-openssl-rand-base64-32

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
# Leave empty to allow all origins in development
# Chrome extensions are automatically allowed
# Example: ALLOWED_ORIGINS=https://app.tabium.com,chrome-extension://abcdefghijklmnop
ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Enable/Disable rate limiting (default: true)
RATE_LIMIT_ENABLED=true

# Window duration in milliseconds (default: 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Max requests per window (default: 60 for prod, 300 for dev)
RATE_LIMIT_MAX_REQUESTS=60

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# Log directory (relative to project root or absolute)
# For Docker, use /data/logs
LOG_DIR=./data/logs

# Log rotation settings
LOG_MAX_SIZE=20m
LOG_MAX_FILES=30d
LOG_ERROR_MAX_FILES=60d

# -----------------------------------------------------------------------------
# Nginx Reverse Proxy (optional - use with docker compose --profile proxy)
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
SSL_CERT_PATH=./nginx/certs

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------
# Enable backups (default: true)
BACKUP_ENABLED=true
BACKUP_RETENTION=10

# -----------------------------------------------------------------------------
# Docker Image Tag
# -----------------------------------------------------------------------------
TAG=latest
