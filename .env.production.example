# =============================================================================
# Tab-Sync-API Production Environment Template
# =============================================================================
# Copy to .env for production deployment.
# Generate fresh secrets for each deployment.
# =============================================================================

# Environment
NODE_ENV=production

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000
API_PORT=3000

# Domain for trusted proxy headers (your public domain)
# Leave empty if accessing directly without a reverse proxy
DOMAIN=api.yourdomain.com

TZ=UTC

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_TYPE=sqlite
DATABASE_PATH=/app/data/tabs.db

# -----------------------------------------------------------------------------
# Authentication - CHANGE THIS!
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=

# -----------------------------------------------------------------------------
# CORS - Add your frontend domains
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=https://yourdomain.com

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_DIR=/app/data/logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=30d
LOG_ERROR_MAX_FILES=60d

# -----------------------------------------------------------------------------
# Nginx Reverse Proxy (optional)
# -----------------------------------------------------------------------------
# Use with: docker compose --profile proxy up -d
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
SSL_CERT_PATH=./nginx/certs

# -----------------------------------------------------------------------------
# Backups
# -----------------------------------------------------------------------------
BACKUP_RETENTION=30

# Image tag
TAG=latest
